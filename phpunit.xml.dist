<?xml version="1.0" encoding="UTF-8"?>
<phpunit bootstrap="vendor/autoload.php">
    <testsuites>
        <testsuite name="unit">
            <directory suffix=".phpt">tests</directory>
            <directory suffix="Test.php">tests</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory suffix=".php">src</directory>
        </include>
        <exclude>
            <!-- Autoload-files shim: runs before coverage starts, so it can never be counted. -->
            <file>src/Unit/bootstrap.php</file>
        </exclude>
    </source>
</phpunit>
